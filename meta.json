{
  "$schema": "https://dl.viam.dev/module.schema.json",
  "module_id": "brad-grigsby:image-processing",
  "visibility": "public",
  "url": "https://github.com/bgrigsby8/image-processing",
  "description": "Modular camera components: color-correction, ptp",
  "applications": null,
  "markdown_link": "README.md",
  "models": [
    {
      "api": "rdk:component:camera",
      "model": "brad-grigsby:image-processing:color-correction",
      "markdown_link": "brad-grigsby_image-processing_color-correction.md",
      "short_description": ""
    },
    {
      "api": "rdk:component:camera",
      "model": "brad-grigsby:image-processing:ptp",
      "markdown_link": "brad-grigsby_image-processing_ptp.md",
      "short_description": "Download images from a USB-connected camera over PTP (libgphoto2)."
    }
  ],
  "entrypoint": "run.sh",
  "first_run": "",
  "build": {
    "build": "./build.sh",
    "setup": "./setup.sh",
    "path": "dist/archive.tar.gz",
    "arch": [
      "linux/amd64",
      "linux/arm64",
      "darwin/arm64"
    ]
  }
}